# .env.example - Variables de entorno para SipSignal
# Copia este archivo a `.env` y rellena los valores reales.
# NO subas `.env` al repositorio (ya está en .gitignore).

# Token del bot de Telegram (obtenido de @BotFather)
TOKEN_TELEGRAM=""

# IDs de Telegram de los administradores (separados por coma)
ADMIN_CHAT_IDS=""  # Ejemplo: 123456789,987654321

# Claves API de Binance
# NOTA: Para datos de mercado (OHLCV, precios), se usa la API pública
# de data-api.binance.vision que NO requiere autenticación.
# Estas claves solo son necesarias si en el futuro se implementa trading.
BINANCE_API_KEY=""
BINANCE_API_SECRET=""

# API key de Groq para análisis con IA
GROQ_API_KEY=""

# API key para capturas de pantalla (opcional)
SCREENSHOT_API_KEY=""

# API keys de CoinMarketCap
CMC_API_KEY_ALERTA=""
CMC_API_KEY_CONTROL=""

# URL de la base de datos PostgreSQL
DATABASE_URL="postgresql://user:pass@localhost:5432/sipsignal_db"

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Entorno de ejecución
ENVIRONMENT="production"
