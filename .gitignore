# Archivos de entorno - ¡MUY IMPORTANTE!
apit.env
.env

# Archivos de datos
# Ignoramos la carpeta 'data' completa para no subir
# archivos JSON de usuarios, alertas o historial.
data/

# Git worktrees
.worktrees/

# Caché de Python y archivos compilados
__pycache__/
*.pyc

# Carpetas de entorno virtual
venv/
.venv/
env/
*.env

# Configuraciones específicas de VS Code
.vscode/
logs/
*.log

# Archivo de versión local (generado automáticamente)
# Cada entorno (local/VPS) mantiene su propia versión
version.txt
.coverage
